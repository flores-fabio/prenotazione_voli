# Configurazione database MariaDB per il backend Flask
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=password
DB_NAME=prenotazione_volo
# Se il server MariaDB usa autenticazione socket, imposta il percorso del socket.
# DB_SOCKET=/var/run/mysqld/mysqld.sock

# Origini CORS per permettere al frontend di Angular di chiamare le API
CORS_ORIGINS=http://localhost:4200
